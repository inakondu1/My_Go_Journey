package main

import (
	"fmt"
	"strings"
)

func hex(s string) string {
	result := ""
	for i := 0; i < len(s); i++ {
		if i > 0 && (i+1)%4 == 0 {
			result += strings.ToUpper(string(s[i]))
		} else {
			result += string(s[i])
		}
	}
	return result
}

func main() {
	fmt.Println(hex("inakondu  gradually becoming  great programer"))
}
